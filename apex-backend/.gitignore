# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment variables — NEVER commit these ────────────────
# These contain API keys, DB passwords, Stripe secrets, Clerk keys
.env
.env.local
.env.production
.env.production.local

# ── Prisma ────────────────────────────────────────────────────
# Keep schema.prisma and migrations tracked, but not local DB files
prisma/*.db
prisma/*.db-journal

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── Build output (if you ever add a build step) ───────────────
dist/

# ── Editor & OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo